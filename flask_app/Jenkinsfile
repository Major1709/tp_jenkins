pipeline {
  agent any

  triggers {
    pollSCM('* * * * *')
  }

  stages {
    stage('Test python') {
      steps {
        dir('flask_app') {
          sh '''
            docker run --rm \
              -v "$PWD:/app" \
              -w /app \
              python:3.11-slim \
              sh -c "pip install --no-cache-dir -r requirements.txt && python test.py -v"
          '''
        }
      }
    }

    stage('Build image') {
      steps {
        dir('flask_app') {
          sh 'docker build -t localhost:4000/pythontest:latest .'
          sh 'docker push localhost:4000/pythontest:latest'
        }
      }
    }

    stage('Deploy') {
      steps {
        dir('flask_app') {
          sh '''
            if command -v kubectl >/dev/null 2>&1; then
              kubectl apply -f ./kubernetes/deployment.yaml
              kubectl apply -f ./kubernetes/service.yaml
            else
              echo "kubectl absent dans Jenkins Docker Compose: deploiement Kubernetes ignore."
            fi
          '''
        }
      }
    }
  }
}
