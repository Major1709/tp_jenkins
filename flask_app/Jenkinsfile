pipeline {
  agent {
    kubernetes {
      label 'jenkins-agent-flask-app'
      yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    component: ci
spec:
  containers:
    - name: python
      image: python:3.11-slim
      imagePullPolicy: IfNotPresent
      command:
        - cat
      tty: true
    - name: docker
      image: docker:26-cli
      imagePullPolicy: IfNotPresent
      command:
        - cat
      tty: true
      volumeMounts:
        - mountPath: /var/run/docker.sock
          name: docker-sock
  volumes:
    - name: docker-sock
      hostPath:
        path: /var/run/docker.sock
"""
    }
  }

  triggers {
    pollSCM('* * * * *')
  }

  stages {
    stage('Test python') {
      steps {
        dir('flask_app') {
          container('python') {
            sh 'pip install --no-cache-dir -r requirements.txt'
            sh 'python test.py -v'
          }
        }
      }
    }

    stage('Build image') {
      steps {
        dir('flask_app') {
          container('docker') {
            sh 'docker build -t localhost:4000/pythontest:latest .'
            sh 'docker push localhost:4000/pythontest:latest'
          }
        }
      }
    }

    stage('Deploy') {
      steps {
        dir('flask_app') {
          container('docker') {
            sh '''
              docker run --rm \
                --network host \
                -v "$PWD/kubernetes:/work/kubernetes" \
                -v /var/run/docker.sock:/var/run/docker.sock \
                bitnami/kubectl:latest \
                apply -f /work/kubernetes/deployment.yaml
            '''
            sh '''
              docker run --rm \
                --network host \
                -v "$PWD/kubernetes:/work/kubernetes" \
                -v /var/run/docker.sock:/var/run/docker.sock \
                bitnami/kubectl:latest \
                apply -f /work/kubernetes/service.yaml
            '''
          }
        }
      }
    }
  }
}
